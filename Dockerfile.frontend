# ── مرحلة البناء ───────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

# ── مرحلة التشغيل (nginx) ──────────────────────────────
FROM nginx:alpine

# نسخ الفرونت المبني
COPY --from=builder /app/dist /usr/share/nginx/html

# إعداد nginx (proxy للـ API + SPA routing)
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
